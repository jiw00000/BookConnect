# ===========================
# KSU Culture Hub - 환경 변수
# ===========================
# 이 파일을 복사하여 .env로 저장하고 값을 채워주세요.

# 서버 설정
PORT=5000
NODE_ENV=development

# MongoDB 연결 URI
# 로컬: mongodb://localhost:27017/ksu_culture
# Atlas: mongodb+srv://<user>:<password>@cluster.mongodb.net/ksu_culture
MONGODB_URI=mongodb://localhost:27017/ksu_culture

# JWT 설정
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your_refresh_secret_key
JWT_REFRESH_EXPIRES_IN=30d

# 허용 학교 이메일 도메인 (콤마 구분)
ALLOWED_EMAIL_DOMAINS=ks.ac.kr

# CORS 허용 오리진 (프론트엔드 URL)
CLIENT_ORIGIN=http://localhost:3000

# 파일 업로드 설정
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=10
